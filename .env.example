# ============================================
# Renovo Cabeleireiros - Configuração
# ============================================
# Copie este arquivo para .env e preencha
# com suas valores reais

# SERVIDOR
# --------
PORT=3000

# GOOGLE GEMINI API
# ----------------
# Obtenha em: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=sua_chave_api_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta

# WHATSAPP CLOUD API
# ------------------
# Obtenha em: https://developers.facebook.com/
WHATSAPP_ACCESS_TOKEN=seu_access_token_whatsapp_aqui
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id_aqui
WHATSAPP_VERIFY_TOKEN=seu_verify_token_unico_aqui
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_NOTIFY_TO=(88)9932949360

# ADMIN
# -----
# ⚠️ TROCAR EM PRODUÇÃO!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

